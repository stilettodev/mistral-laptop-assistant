# your Mistral API key – get one at https://console.mistral.ai/
MLA_MISTRAL_API_KEY=

# default model. Use "auto" to let the agent pick per task,
# or pin to e.g. mistral-large-latest / codestral-latest / etc.
MLA_DEFAULT_MODEL=auto

# tiny/cheap model used to classify the task in auto mode
MLA_ROUTER_MODEL=ministral-3b-latest

# server bind address
MLA_HOST=127.0.0.1
MLA_PORT=8000

# safety mode: strict | normal | yolo
#   strict – confirm every non-read action
#   normal – confirm only risky / destructive actions   (default)
#   yolo   – never ask (use at your own risk)
MLA_SAFETY_MODE=normal

# limit how far the assistant can wander in your filesystem
# (defaults to your home directory)
# MLA_WORKSPACE_DIR=/Users/you

# location of the append-only audit log of every tool call
# MLA_AUDIT_LOG=/Users/you/.mistral_assistant_audit.log

# max tool-call iterations per user turn
MLA_MAX_AGENT_STEPS=20

# shell command timeout in seconds
MLA_SHELL_TIMEOUT_SECONDS=120
